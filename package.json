{
  "name": "clavue-agent-sdk",
  "author": {
    "name": "mycode699",
    "url": "https://github.com/mycode699"
  },
  "homepage": "https://github.com/mycode699/clavue-agent-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mycode699/clavue-agent-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/mycode699/clavue-agent-sdk/issues"
  },
  "version": "0.7.2",
  "description": "In-process TypeScript agent runtime for controlled autonomous coding, research, issue workflows, durable AgentJobs, memory, and CI automation.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clavue-agent-sdk": "dist/cli.js",
    "clavue-agent": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "dev": "tsc --watch",
    "test": "npx tsx --test tests/*.test.ts",
    "test:all": "node --import tsx examples/16-background-agent-jobs.ts",
    "test:examples:live": "for f in examples/*.ts; do echo \"--- Running $f ---\"; npx tsx $f; echo; done",
    "web": "npx tsx examples/web/server.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "clavue-agent-sdk",
    "agent-sdk",
    "ai-agent",
    "autonomous-agent",
    "coding-agent",
    "agentic",
    "llm",
    "tools",
    "mcp",
    "openai",
    "anthropic",
    "workflow-automation",
    "ci-automation",
    "issue-workflow",
    "typescript"
  ],
  "license": "MIT"
}
